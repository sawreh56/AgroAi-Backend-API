# Server Configuration
PORT=4000
NODE_ENV=production

# Frontend origins allowed to call API (comma separated)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Database
DB_URL=mongodb+srv://username:password@cluster.mongodb.net/databasename?retryWrites=true&w=majority

# JWT Secrets
JWT_SECRET_KEY=replace_with_min_32_char_random_secret
JWT_REFRESH_KEY=replace_with_min_32_char_random_refresh_secret

# Email Configuration (Gmail)
EMAIL=your_email@gmail.com
PASS_CODE=your_app_password_here

# OTP Security
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# DNS Servers (Optional)
DNS_SERVERS=8.8.8.8,1.1.1.1
