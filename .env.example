# Server Configuration
PORT=4000

# Database
DB_URL=mongodb+srv://username:password@cluster.mongodb.net/databasename?retryWrites=true&w=majority

# JWT Secrets
JWT_SECRET_KEY=your_secret_key_here_for_access_token
JWT_REFRESH_KEY=your_refresh_key_here_for_refresh_token

# Email Configuration (Gmail)
EMAIL=your_email@gmail.com
PASS_CODE=your_app_password_here

# DNS Servers (Optional)
DNS_SERVERS=8.8.8.8,1.1.1.1
